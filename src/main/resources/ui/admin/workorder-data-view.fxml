                <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                                vgrow="NEVER"/>
                <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                                vgrow="NEVER"/>
            </rowConstraints>
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <Label text="Plant Element" GridPane.rowIndex="5">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <TextField fx:id="plantElementField" promptText="Inst / Equipment / Element Tag..."
                       GridPane.rowIndex="6"/>
            <Button alignment="CENTER" maxWidth="300.0" minWidth="220.0" mnemonicParsing="false"
                    onAction="#searchPlantElement" prefWidth="220.0" text="Search" GridPane.rowIndex="7"/>
            <Label layoutX="10.0" layoutY="26.0" text="Task Description" GridPane.rowIndex="9">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <TextArea fx:id="workOrderDescriptionArea" prefHeight="110.0" prefWidth="700.0"
                      promptText="Work description / actions..." GridPane.columnSpan="4"
                      GridPane.rowIndex="10" GridPane.rowSpan="3"/>
            <Label layoutX="10.0" layoutY="30.0" text="Category" GridPane.columnIndex="2"
                   GridPane.rowIndex="5">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <ChoiceBox fx:id="workOrderCategorySelector" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"
                       GridPane.columnIndex="2" GridPane.rowIndex="6"/>
            <Button alignment="CENTER" layoutX="10.0" layoutY="116.0" maxWidth="300.0" minWidth="220.0"
                    mnemonicParsing="false" onAction="#addWorkOrderCategory" prefWidth="220.0" text="Select"
                    GridPane.columnIndex="2" GridPane.rowIndex="7"/>
            <Label fx:id="tagLabel" text="TAG: " GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            <Label fx:id="locationLabel" text="LOCATION: " GridPane.columnIndex="1"
                   GridPane.rowIndex="7"/>
            <Label fx:id="descriptionLabel" text="DESCRIPTION: " GridPane.columnIndex="1"
                   GridPane.rowIndex="8"/>
            <ListView fx:id="workOrderCategoryView" maxWidth="300.0" minWidth="220.0" prefHeight="110.0"
                      prefWidth="220.0" GridPane.columnIndex="3" GridPane.rowIndex="6" GridPane.rowSpan="3"
                      GridPane.vgrow="NEVER"/>
            <Separator prefWidth="200.0" GridPane.columnSpan="4" GridPane.rowIndex="4"/>
            <CheckBox fx:id="cBoxWorkPermit" mnemonicParsing="false" onAction="#toggleWorkPermitTab"
                      text="Add Work Permit" GridPane.rowIndex="3"/>
            <CheckBox fx:id="cBoxWorkProcedure" mnemonicParsing="false" onAction="#toggleWorkProcedureTab"
                      text="Add Work procedure" GridPane.rowIndex="2"/>
            <CheckBox fx:id="cBoxSchedule" mnemonicParsing="false" onAction="#toggleValidPeriodTab"
                      text="Schedule Work Order" GridPane.rowIndex="1"/>
            <Label layoutX="30.0" layoutY="32.0" text="Options">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <Label text="Holder" GridPane.rowIndex="13">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <ChoiceBox fx:id="holderSelector" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"
                       GridPane.rowIndex="14"/>
            <Button maxWidth="300.0" minWidth="220.0" mnemonicParsing="false" onAction="#selectHolder"
                    prefWidth="220.0" text="Select" GridPane.rowIndex="15"/>
            <Label fx:id="holderName" text="NAME:" GridPane.columnIndex="1" GridPane.rowIndex="14"/>
            <Label fx:id="holderContact" text="CONTACT: " GridPane.columnIndex="1" GridPane.rowIndex="15"/>
            <Label text="Technicians" GridPane.columnIndex="2" GridPane.rowIndex="13">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <ChoiceBox fx:id="technicianSelector" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"
                       GridPane.columnIndex="2" GridPane.rowIndex="14"/>
            <Button maxWidth="300.0" minWidth="220.0" mnemonicParsing="false" onAction="#addTechnician"
                    prefWidth="220.0" text="Add" GridPane.columnIndex="2" GridPane.rowIndex="15"/>
            <Button maxWidth="300.0" minWidth="220.0" mnemonicParsing="false"
                    onAction="#clearTechnicianList" prefWidth="220.0" text="Clean list"
                    GridPane.columnIndex="2" GridPane.rowIndex="16"/>
            <ListView fx:id="participantView" prefHeight="110.0" GridPane.columnIndex="3"
                      GridPane.rowIndex="14" GridPane.rowSpan="3"/>
            <Label text="Spare Parts" GridPane.rowIndex="18">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
            <Label text="Number of spare parts to be used:" GridPane.rowIndex="21"/>
            <Button maxWidth="300.0" minWidth="220.0" mnemonicParsing="false" onAction="#addSparePart"
                    prefWidth="220.0" text="Add" GridPane.rowIndex="23"/>
            <TextField fx:id="sparePartField" GridPane.rowIndex="20"/>
            <Spinner fx:id="numSelected" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"
                     GridPane.rowIndex="22"/>
            <ChoiceBox fx:id="sparePartSearch" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"
                       GridPane.rowIndex="19"/>
            <Button maxWidth="300.0" minWidth="220.0" mnemonicParsing="false" onAction="#cleanSparePartList"
                    prefWidth="220.0" text="Clean list" GridPane.rowIndex="24"/>
            <Separator layoutX="30.0" layoutY="254.0" prefWidth="200.0" GridPane.columnSpan="4"
                       GridPane.rowIndex="17"/>
            <TableView fx:id="sparePartTable" GridPane.columnIndex="1" GridPane.columnSpan="3"
                       GridPane.rowIndex="19" GridPane.rowSpan="6">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            <ListView fx:id="sparePartSelectedView" GridPane.columnSpan="4" GridPane.rowIndex="25"
                      GridPane.rowSpan="5" GridPane.vgrow="ALWAYS"/>
            <Button layoutX="626.0" layoutY="654.0" maxWidth="300.0" minWidth="220.0"
                    mnemonicParsing="false" onAction="#clearCategoryList" prefWidth="220.0"
                    text="Clean list" GridPane.columnIndex="2" GridPane.rowIndex="8"/>
        </GridPane>
    </ScrollPane>
</StackPane>

