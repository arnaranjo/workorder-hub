<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<StackPane
        xmlns="http://javafx.com/javafx/22"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.workorderhub.provider.ui.admin.WorkOrderDataController"
        prefHeight="961.0"
        prefWidth="1226.0"
        maxHeight="-Infinity"
        maxWidth="-Infinity"
>
    <ScrollPane fx:id="miScroll"
                fitToHeight="true"
                fitToWidth="true"
                prefHeight="961.0"
                prefWidth="1226.0"
                hbarPolicy="NEVER"
                vbarPolicy="ALWAYS"
                prefViewportHeight="640.0"
                prefViewportWidth="1024.0"
    >
        <GridPane alignment="TOP_CENTER" hgap="20.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                                vgrow="NEVER"/>
                <RowConstraints minHeight="20.0" prefHeight="20.0" valignment="CENTER" vgrow="NEVER"/>
                <RowConstraints minHeight="20.0" prefHeight="20.0" valignment="CENTER" vgrow="NEVER"/>
                <RowConstraints minHeight="20.0" prefHeight="20.0" valignment="CENTER" vgrow="NEVER"/>
