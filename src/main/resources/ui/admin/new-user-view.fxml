<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefWidth="400.0"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.workorderhub.provider.ui.admin.NewUserController"
>
    <padding>
        <Insets bottom="20.0"/>
    </padding>
    <Label fx:id="newUserLabel" alignment="CENTER" contentDisplay="TOP" prefWidth="400.0">
        <font>
            <Font size="18.0"/>
        </font>
        <padding>
            <Insets bottom="10.0" top="15.0"/>
        </padding>
    </Label>
    <VBox spacing="10.0">
        <VBox.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </VBox.margin>
        <Label text="Name"/>
        <TextField fx:id="nameField"/>
        <Label text="Phone number"/>
        <TextField fx:id="phoneField"/>
        <Label text="E-Mail"/>
        <TextField fx:id="emailField"/>
        <Label text="Role"/>
        <ComboBox fx:id="rolBox" prefHeight="30.0" prefWidth="460.0"/>
        <Separator prefWidth="200.0"/>
        <Label text="User credentials">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Label text="Login name"/>
        <TextField fx:id="loginNameField"/>
        <Label text="Password"/>
        <PasswordField fx:id="passwordField"/>
        <Label layoutX="10.0" layoutY="386.0" text="Confirm password"/>
        <PasswordField fx:id="confPasswordField" layoutX="10.0" layoutY="414.0"/>
    </VBox>
    <HBox alignment="CENTER" prefWidth="200.0">
        <Button mnemonicParsing="false" onAction="#createUser" prefWidth="100.0" text="Add User">
            <HBox.margin>
                <Insets right="10.0"/>
            </HBox.margin>
        </Button>
        <Button mnemonicParsing="false" onAction="#clearFields" prefWidth="100.0" text="Clear Fields">
            <HBox.margin>
                <Insets left="10.0"/>
            </HBox.margin>
        </Button>
    </HBox>
</VBox>
