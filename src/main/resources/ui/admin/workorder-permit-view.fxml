<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.StackPane?>
<StackPane
        xmlns="http://javafx.com/javafx/22"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.workorderhub.provider.ui.admin.WorkOrderPermitController"
        prefHeight="961.0"
        prefWidth="1226.0"
        maxHeight="-Infinity"
        maxWidth="-Infinity"
>
    <GridPane alignment="TOP_CENTER" hgap="20.0" nodeOrientation="LEFT_TO_RIGHT" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
            <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
            <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="220.0" prefWidth="220.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                            vgrow="NEVER"/>
            <RowConstraints valignment="CENTER" vgrow="NEVER"/>
            <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                            vgrow="NEVER"/>
            <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                            vgrow="NEVER"/>
            <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                            vgrow="NEVER"/>
            <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                            vgrow="NEVER"/>
            <RowConstraints maxHeight="30.0" minHeight="30.0" prefHeight="30.0" valignment="CENTER"
                            vgrow="NEVER"/>
            <RowConstraints valignment="CENTER" vgrow="ALWAYS"/>
            <RowConstraints/>
            <RowConstraints valignment="CENTER" vgrow="NEVER"/>
        </rowConstraints>
        <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
        <Label text="Description">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
        <Label layoutX="10.0" layoutY="26.0" text="Safety Lock" GridPane.rowIndex="3">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
        <TextArea fx:id="workPermitDescriptionArea" minHeight="100.0" prefHeight="100.0"
                  promptText="Risks and preventive measures..." GridPane.columnSpan="3"
                  GridPane.rowIndex="1"/>
        <Button fx:id="selectLotoButton" maxWidth="300.0" minWidth="220.0" mnemonicParsing="false"
                onAction="#selectLotoProcedure" prefWidth="220.0" text="Select" GridPane.rowIndex="8">
            <GridPane.margin>
                <Insets/>
            </GridPane.margin>
        </Button>
        <TextField fx:id="lockDevicesField" promptText="Locking devices codes..." GridPane.columnIndex="1"
                   GridPane.columnSpan="2" GridPane.rowIndex="4"/>
        <TableView fx:id="lotoProcedureTable" minHeight="200.0" GridPane.columnSpan="3"
                   GridPane.rowIndex="7" GridPane.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
        <Label text="LOTO Procedure" GridPane.rowIndex="5">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
        <CheckBox fx:id="cBoxLoto" mnemonicParsing="false" onAction="#toggleLoto"
                  text="Does an element need to be locked?" GridPane.rowIndex="4"/>
        <TextField fx:id="lotoProcedureField" maxWidth="Infinity" minWidth="220.0"
                   prefWidth="220.0" GridPane.columnIndex="1" GridPane.columnSpan="2"
                   GridPane.rowIndex="6"/>
        <ChoiceBox fx:id="lotoProcedureSearch" maxWidth="300.0" minWidth="220.0" GridPane.columnSpan="2"
                   GridPane.rowIndex="6"/>
        <Separator prefWidth="200.0" GridPane.columnSpan="2" GridPane.rowIndex="2"/>
        <Label fx:id="lotoProcedureCode" text="SELECTED" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
    </GridPane>
</StackPane>
