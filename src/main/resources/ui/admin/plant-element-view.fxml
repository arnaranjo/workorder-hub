<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.workorderhub.provider.ui.admin.PlantElementController"
>
    <top>
        <Label fx:id="mainLabel" alignment="CENTER" maxWidth="Infinity" prefHeight="50.0" prefWidth="1000.0"
               BorderPane.alignment="CENTER">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
    </top>
    <center>
        <TableView fx:id="plantElementsTable" editable="true" BorderPane.alignment="CENTER">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <Pane prefHeight="30.0" BorderPane.alignment="CENTER">
            <Label fx:id="infoLabel" layoutX="14.0" layoutY="6.0"/>
        </Pane>
    </bottom>
    <left>
        <Accordion fx:id="accordion" BorderPane.alignment="CENTER">
            <panes>
                <TitledPane animated="false" text="Add Element">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                        </padding>
                        <Label text="Tag"/>
                        <TextField fx:id="tagField"/>
                        <Label text="Description"/>
                        <TextArea fx:id="descriptionArea" prefHeight="100.0" prefWidth="220.0"/>
                        <Label text="Location"/>
                        <TextField fx:id="locationField"/>
                        <Label text="Inspection Date"/>
                        <DatePicker fx:id="inspectionDatePicker" editable="false" prefWidth="220.0"
                                    promptText="Set the next inspection date">
                            <VBox.margin>
                                <Insets bottom="10.0"/>
                            </VBox.margin>
                        </DatePicker>
                        <CheckBox fx:id="inspectionFrcSelector" mnemonicParsing="false" onAction="#ToggleSpinner"
                                  text="Monthly Check Frequency">
                            <VBox.margin>
                                <Insets/>
                            </VBox.margin>
                        </CheckBox>
                        <Spinner fx:id="inspectionFrqSpinner" prefWidth="220.0">
                            <VBox.margin>
                                <Insets bottom="10.0"/>
                            </VBox.margin>
                        </Spinner>
                        <Button mnemonicParsing="false" onAction="#AddElement" prefWidth="220.0" text="Add"/>
                    </VBox>
                </TitledPane>
                <TitledPane animated="false" layoutX="10.0" layoutY="10.0" text="Search Element">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                        </padding>
                        <Label text="Search by:"/>
                        <ChoiceBox fx:id="searchCriteriaSelector" prefWidth="220.0"/>
                        <TextField fx:id="tagSearchField">
                            <opaqueInsets>
                                <Insets/>
                            </opaqueInsets>
                            <VBox.margin>
                                <Insets bottom="10.0"/>
                            </VBox.margin>
                        </TextField>
                    </VBox>
                </TitledPane>
                <TitledPane animated="false" layoutX="10.0" layoutY="36.0" text="Delete Element">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                        </padding>
                        <Label fx:id="elementSelectedLabel" text="Element selected"/>
                        <Button mnemonicParsing="false" onAction="#DeleteElement" prefWidth="220.0" text="Delete"/>
                    </VBox>
                </TitledPane>
            </panes>
        </Accordion>
    </left>
</BorderPane>
