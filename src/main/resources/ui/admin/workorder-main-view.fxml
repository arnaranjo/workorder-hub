<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.StackPane?>
<BorderPane prefHeight="768.0" prefWidth="1366.0"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.workorderhub.provider.ui.admin.WorkOrderMainController"
>
    <top>
        <Label fx:id="mainLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="Infinity" prefHeight="50.0"
               prefWidth="800.0" BorderPane.alignment="CENTER">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" tabMaxHeight="25.0" tabMaxWidth="150.0" tabMinHeight="25.0"
                 tabMinWidth="150.0" BorderPane.alignment="CENTER">
            <Tab closable="false" text="Work Order Data">
                <StackPane>
                    <fx:include fx:id="dataView" source="workorder-data-view.fxml"/>
                </StackPane>
            </Tab>
            <Tab fx:id="validPeriodTab" closable="false" text="Work Order Data">
                <StackPane>
                    <fx:include fx:id="validPeriodView" source="workorder-valid-period-view.fxml"/>
                </StackPane>
            </Tab>
            <Tab fx:id="workProcedureTab" closable="false" text="Work Procedure">
                <StackPane>
                    <fx:include fx:id="workProcedureView" source="workorder-procedure-view.fxml"/>
                </StackPane>
            </Tab>
            <Tab fx:id="workPermitTab" closable="false" text="Work Permit">
                <StackPane>
                    <fx:include fx:id="workPermitView" source="workorder-permit-view.fxml"/>
                </StackPane>
            </Tab>
        </TabPane>
    </center>
    <left>
        <VBox BorderPane.alignment="CENTER">
            <Button mnemonicParsing="false" onAction="#CreateNewWorkOrder" prefWidth="100.0" text="Open Order">
                <VBox.margin>
                    <Insets left="20.0" right="20.0" top="10.0"/>
                </VBox.margin>
            </Button>
            <Button layoutX="30.0" layoutY="20.0" mnemonicParsing="false" prefWidth="100.0" text="Save Changes">
                <VBox.margin>
                    <Insets left="20.0" right="20.0" top="10.0"/>
                </VBox.margin>
            </Button>
        </VBox>
    </left>
</BorderPane>
